---
import { getPostListing } from '../../lib/postListing'
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import PostListingPage from '../../components/PostListingPage.astro';


const sorted =  await getPostListing("notes");
---

<PostListingPage
  title="Notes"
  basePath="/notes"
  entries={sorted}
  pageTitle={`Notes - ${SITE_TITLE}`}
  description={SITE_DESCRIPTION}
/> 