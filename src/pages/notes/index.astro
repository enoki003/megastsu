---
import { getPostListing } from '../../lib/postListing';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostPanel from '../../components/PostPanel.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const sorted =  await getPostListing("notes");
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <BaseHead title={`Notes - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      .card-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        list-style: none;
        padding: 0;
        margin: 0;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>Notes</h1>
      <ul class="card-list">
        {sorted.map((e) => (
          <li>
            <PostPanel
              href={`/notes/${e.slug}/`}
              title={e.data.title}
              date={e.data.date}
              description={e.data.description}
            />
          </li>
        ))}
      </ul>
    </main>
    <Footer />
  </body>
</html>
  </body>
</html>