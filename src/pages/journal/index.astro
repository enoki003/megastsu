---
import { getPostListing } from '../../lib/postListing';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import PostListingPage from '../../components/PostListingPage.astro';

const sorted =  await getPostListing("journal");
---

<PostListingPage
  title="Journal"
  basePath="/journal"
  entries={sorted}
  pageTitle={`Journal - ${SITE_TITLE}`}
  description={SITE_DESCRIPTION}
/>